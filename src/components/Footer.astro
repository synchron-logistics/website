---
---

<footer class="bg-[#0a0a0a] text-white">
  <div class="max-w-7xl mx-auto px-6 py-16">
    <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-4 gap-10">

      <!-- Column 1: Logo + Tagline + Social -->
      <div class="flex flex-col gap-6">
        <a href="/" class="flex items-center gap-3">
          <div class="bg-white w-12 h-12 flex items-center justify-center flex-shrink-0">
            <svg class="w-7 h-7 text-[#0a0a0a]" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <circle cx="12" cy="12" r="10" stroke-width="1.5"/>
              <path stroke-width="1.5" stroke-linecap="round"
                d="M2 12h20M12 2a15.3 15.3 0 014 10 15.3 15.3 0 01-4 10 15.3 15.3 0 01-4-10 15.3 15.3 0 014-10z"/>
            </svg>
          </div>
          <div class="leading-tight">
            <div class="font-heading font-bold text-xl tracking-wider text-white">SYNCHRON</div>
            <div class="font-body text-xs tracking-widest text-white uppercase">Logistics</div>
          </div>
        </a>
        <p class="font-body text-gray-400 text-sm leading-relaxed">
          Providing world-class logistics and supply chain solutions since 2000. We move your business forward with precision and reliability.
        </p>
        <div class="flex gap-3">
          {[
            { label: 'Facebook', path: 'M18 2h-3a5 5 0 00-5 5v3H7v4h3v8h4v-8h3l1-4h-4V7a1 1 0 011-1h3z' },
            { label: 'Twitter', path: 'M23 3a10.9 10.9 0 01-3.14 1.53 4.48 4.48 0 00-7.86 3v1A10.66 10.66 0 013 4s-4 9 5 13a11.64 11.64 0 01-7 2c9 5 20 0 20-11.5a4.5 4.5 0 00-.08-.83A7.72 7.72 0 0023 3z' },
            { label: 'LinkedIn', path: 'M16 8a6 6 0 016 6v7h-4v-7a2 2 0 00-2-2 2 2 0 00-2 2v7h-4v-7a6 6 0 016-6zM2 9h4v12H2z M4 6a2 2 0 100-4 2 2 0 000 4z' },
            { label: 'Instagram', path: 'M12 2.163c3.204 0 3.584.012 4.85.07 3.252.148 4.771 1.691 4.919 4.919.058 1.265.069 1.645.069 4.849 0 3.205-.012 3.584-.069 4.849-.149 3.225-1.664 4.771-4.919 4.919-1.266.058-1.644.07-4.85.07-3.204 0-3.584-.012-4.849-.07-3.26-.149-4.771-1.699-4.919-4.92-.058-1.265-.07-1.644-.07-4.849 0-3.204.013-3.583.07-4.849.149-3.227 1.664-4.771 4.919-4.919 1.266-.057 1.645-.069 4.849-.069zm0-2.163c-3.259 0-3.667.014-4.947.072-4.358.2-6.78 2.618-6.98 6.98-.059 1.281-.073 1.689-.073 4.948 0 3.259.014 3.668.072 4.948.2 4.358 2.618 6.78 6.98 6.98 1.281.058 1.689.072 4.948.072 3.259 0 3.668-.014 4.948-.072 4.354-.2 6.782-2.618 6.979-6.98.059-1.28.073-1.689.073-4.948 0-3.259-.014-3.667-.072-4.947-.196-4.354-2.617-6.78-6.979-6.98-1.281-.059-1.69-.073-4.949-.073zm0 5.838a6.162 6.162 0 100 12.324 6.162 6.162 0 000-12.324zM12 16a4 4 0 110-8 4 4 0 010 8zm6.406-11.845a1.44 1.44 0 100 2.881 1.44 1.44 0 000-2.881z' },
          ].map(social => (
            <a
              href="#"
              aria-label={social.label}
              class="w-10 h-10 rounded-full bg-gray-800 flex items-center justify-center hover:bg-[#e31937] transition-colors"
            >
              <svg class="w-4 h-4 text-white" fill="currentColor" viewBox="0 0 24 24">
                <path d={social.path}/>
              </svg>
            </a>
          ))}
        </div>
      </div>

      <!-- Column 2: Navigation -->
      <div>
        <h4 class="font-heading font-bold text-sm tracking-widest uppercase mb-6 text-white">Navigation</h4>
        <ul class="flex flex-col gap-3">
          {['Home', 'About Us', 'Services', 'Track Shipment', 'Contact'].map(item => (
            <li>
              <a href="#" class="font-body text-gray-400 text-sm hover:text-[#e31937] transition-colors">{item}</a>
            </li>
          ))}
        </ul>
      </div>

      <!-- Column 3: Services -->
      <div>
        <h4 class="font-heading font-bold text-sm tracking-widest uppercase mb-6 text-white">Services</h4>
        <ul class="flex flex-col gap-3">
          {['Ocean Freight', 'Air Freight', 'Road Transport', 'Warehousing', 'Supply Chain Consulting'].map(item => (
            <li>
              <a href="#" class="font-body text-gray-400 text-sm hover:text-[#e31937] transition-colors">{item}</a>
            </li>
          ))}
        </ul>
      </div>

      <!-- Column 4: Contact -->
      <div>
        <h4 class="font-heading font-bold text-sm tracking-widest uppercase mb-6 text-white">Contact</h4>
        <ul class="flex flex-col gap-4">
          <li class="flex items-start gap-3">
            <svg class="w-5 h-5 text-[#e31937] flex-shrink-0 mt-0.5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z"/>
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 11a3 3 0 11-6 0 3 3 0 016 0z"/>
            </svg>
            <span class="font-body text-gray-400 text-sm leading-relaxed">123 Logistics Way, Suite 500<br/>New York, NY 10001</span>
          </li>
          <li class="flex items-center gap-3">
            <svg class="w-5 h-5 text-[#e31937] flex-shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2"
                d="M3 5a2 2 0 012-2h3.28a1 1 0 01.948.684l1.498 4.493a1 1 0 01-.502 1.21l-2.257 1.13a11.042 11.042 0 005.516 5.516l1.13-2.257a1 1 0 011.21-.502l4.493 1.498a1 1 0 01.684.949V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 6V5z"/>
            </svg>
            <a href="tel:+18005550123" class="font-body text-gray-400 text-sm hover:text-[#e31937] transition-colors">+1 (800) 555-0123</a>
          </li>
          <li class="flex items-center gap-3">
            <svg class="w-5 h-5 text-[#e31937] flex-shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 8l7.89 5.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z"/>
            </svg>
            <a href="mailto:info@synchronlogistics.com" class="font-body text-gray-400 text-sm hover:text-[#e31937] transition-colors">info@synchronlogistics.com</a>
          </li>
        </ul>
      </div>

    </div>
  </div>

  <!-- Bottom Bar -->
  <div class="border-t border-gray-800">
    <div class="max-w-7xl mx-auto px-6 py-5 flex flex-col sm:flex-row items-center justify-between gap-4">
      <p class="font-body text-gray-500 text-sm">© 2026 Synchron Logistics. All rights reserved.</p>
      <div class="flex items-center gap-6">
        <a href="#" class="font-body text-gray-500 text-sm hover:text-white transition-colors">Privacy Policy</a>
        <a href="#" class="font-body text-gray-500 text-sm hover:text-white transition-colors">Terms of Service</a>
        <a href="#" class="font-body text-gray-500 text-sm hover:text-white transition-colors">Sitemap</a>
      </div>
    </div>
  </div>
</footer>
