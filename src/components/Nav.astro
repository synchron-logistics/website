---
const navLinks = [
  { label: 'HOME', href: '/' },
  { label: 'SERVICES', href: '/services' },
  { label: 'TRACKING', href: '/tracking' },
  { label: 'ABOUT US', href: '/about' },
  { label: 'CONTACT', href: '/contact' },
];

const currentPath = Astro.url.pathname;
---

<!-- Top Bar -->
<div class="bg-[#0a0a0a] text-white text-sm py-2 px-6 flex items-center gap-6">
  <div class="flex items-center gap-2">
    <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
      <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2"
        d="M3 5a2 2 0 012-2h3.28a1 1 0 01.948.684l1.498 4.493a1 1 0 01-.502 1.21l-2.257 1.13a11.042 11.042 0 005.516 5.516l1.13-2.257a1 1 0 011.21-.502l4.493 1.498a1 1 0 01.684.949V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 6V5z"/>
    </svg>
    <span>+1 (800) 555-0123</span>
  </div>
  <span class="text-gray-400">Global Logistics &amp; Supply Chain Solutions</span>
</div>

<!-- Navigation -->
<nav class="bg-white sticky top-0 z-50 shadow-sm" id="main-nav">
  <div class="max-w-7xl mx-auto px-6 flex items-center justify-between h-20">
    <!-- Logo -->
    <a href="/" class="flex items-center gap-3 flex-shrink-0">
      <div class="bg-[#0a0a0a] w-12 h-12 flex items-center justify-center">
        <svg class="w-7 h-7 text-white" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <circle cx="12" cy="12" r="10" stroke-width="1.5"/>
          <path stroke-width="1.5" stroke-linecap="round"
            d="M2 12h20M12 2a15.3 15.3 0 014 10 15.3 15.3 0 01-4 10 15.3 15.3 0 01-4-10 15.3 15.3 0 014-10z"/>
        </svg>
      </div>
      <div class="leading-tight">
        <div class="font-heading font-bold text-xl tracking-wider text-[#0a0a0a]">SYNCHRON</div>
        <div class="font-body text-xs tracking-widest text-[#0a0a0a] uppercase">Logistics</div>
      </div>
    </a>

    <!-- Desktop Links -->
    <ul class="hidden lg:flex items-center gap-8">
      {navLinks.map(link => (
        <li>
          <a
            href={link.href}
            class={`font-body font-semibold text-sm tracking-widest uppercase transition-colors hover:text-[#e31937] ${
              currentPath === link.href || (link.href !== '/' && currentPath.startsWith(link.href))
                ? 'text-[#e31937]'
                : 'text-[#0a0a0a]'
            }`}
          >
            {link.label}
          </a>
        </li>
      ))}
    </ul>

    <!-- Get a Quote Button -->
    <a
      href="/contact"
      class="hidden lg:block bg-[#e31937] text-white font-heading font-bold tracking-widest uppercase text-sm px-6 py-4 hover:bg-[#c41530] hover:scale-[1.02] transition-all duration-200"
    >
      GET A QUOTE
    </a>

    <!-- Mobile Hamburger -->
    <button
      id="hamburger"
      class="lg:hidden flex flex-col gap-1.5 p-2"
      aria-label="Toggle menu"
    >
      <span class="block w-6 h-0.5 bg-[#0a0a0a] transition-all" id="ham-1"></span>
      <span class="block w-6 h-0.5 bg-[#0a0a0a] transition-all" id="ham-2"></span>
      <span class="block w-6 h-0.5 bg-[#0a0a0a] transition-all" id="ham-3"></span>
    </button>
  </div>

  <!-- Mobile Menu -->
  <div id="mobile-menu" class="hidden lg:hidden bg-white border-t border-gray-100 px-6 pb-6">
    <ul class="flex flex-col gap-4 pt-4">
      {navLinks.map(link => (
        <li>
          <a
            href={link.href}
            class={`font-body font-semibold text-sm tracking-widest uppercase transition-colors hover:text-[#e31937] ${
              currentPath === link.href ? 'text-[#e31937]' : 'text-[#0a0a0a]'
            }`}
          >
            {link.label}
          </a>
        </li>
      ))}
      <li>
        <a
          href="/contact"
          class="inline-block bg-[#e31937] text-white font-heading font-bold tracking-widest uppercase text-sm px-6 py-3 hover:bg-red-700 transition-colors"
        >
          GET A QUOTE
        </a>
      </li>
    </ul>
  </div>
</nav>

<script>
  const hamburger = document.getElementById('hamburger');
  const mobileMenu = document.getElementById('mobile-menu');
  const ham1 = document.getElementById('ham-1');
  const ham2 = document.getElementById('ham-2');
  const ham3 = document.getElementById('ham-3');
  let open = false;

  hamburger?.addEventListener('click', () => {
    open = !open;
    mobileMenu?.classList.toggle('hidden', !open);
    if (ham1 && ham2 && ham3) {
      if (open) {
        ham1.style.transform = 'translateY(8px) rotate(45deg)';
        ham2.style.opacity = '0';
        ham3.style.transform = 'translateY(-8px) rotate(-45deg)';
      } else {
        ham1.style.transform = '';
        ham2.style.opacity = '';
        ham3.style.transform = '';
      }
    }
  });
</script>
