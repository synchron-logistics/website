---
import Layout from '../layouts/Layout.astro';
import { site } from '../../site.config.js';
---

<Layout title={site.seo.defaultTitle} description={site.seo.defaultDescription}>

  <!-- HERO SECTION -->
  <section
    class="relative h-screen min-h-[600px] flex items-center"
    style="background-image: url('/images/synchron-logistics-supply-chain-excellence.jpg'); background-size: cover; background-position: center;"
  >
    <!-- Gradient overlay -->
    <div class="absolute inset-0" style="background: linear-gradient(to right, rgba(10,10,10,0.88) 0%, rgba(10,10,10,0.65) 50%, rgba(10,10,10,0.15) 100%);"></div>

    <div class="relative z-10 max-w-7xl mx-auto px-6 w-full">
      <div class="max-w-2xl hero-float" id="hero-content">
        <!-- Eyebrow -->
        <p class="font-heading font-bold text-sm tracking-widest uppercase text-[#e31937] mb-4 hero-eyebrow">
          INTERNATIONAL FREIGHT & LOGISTICS
        </p>

        <!-- Heading -->
        <h1 class="font-heading font-bold uppercase leading-none mb-4">
          <span
            class="block text-6xl md:text-8xl lg:text-9xl hero-line-1"
            style="color: transparent; -webkit-text-stroke: 2px rgba(255,255,255,0.75);"
          >
            SUPPLY CHAIN
          </span>
          <span class="block text-6xl md:text-8xl lg:text-9xl text-white hero-line-2">
            EXCELLENCE.
          </span>
        </h1>

        <!-- Subtext with red left border -->
        <div class="flex items-stretch gap-4 mb-10 max-w-lg hero-subtext">
          <div class="w-1 bg-[#e31937] flex-shrink-0"></div>
          <p class="font-body text-white text-lg leading-relaxed">
            Full-service freight forwarding, inland distribution, and supply chain logistics. 24/7/365.
          </p>
        </div>

        <!-- Buttons -->
        <div class="flex flex-wrap gap-4 hero-buttons">
          <a
            href="/services"
            class="font-heading font-bold uppercase tracking-widest text-sm px-8 py-4 bg-[#e31937] text-white hover:bg-[#c41530] hover:scale-[1.02] transition-all duration-200"
          >
            EXPLORE SERVICES
          </a>
          <a
            href="/contact"
            class="font-heading font-bold uppercase tracking-widest text-sm px-8 py-4 border-2 border-white text-white hover:bg-white hover:text-[#0a0a0a] transition-all duration-200"
          >
            GET A QUOTE
          </a>
        </div>
      </div>
    </div>
  </section>

  <!-- ASIA PACIFIC DIFFERENTIATOR STRIP -->
  <section class="bg-[#0a0a0a] border-t border-gray-800 py-14 reveal">
    <div class="max-w-7xl mx-auto px-6">
      <div class="grid grid-cols-1 md:grid-cols-2 gap-10 items-center">
        <div>
          <p class="font-heading font-bold text-sm tracking-widest uppercase text-[#e31937] mb-3">LOCATION ADVANTAGE</p>
          <h2 class="font-heading font-bold text-4xl md:text-5xl text-white uppercase leading-tight">
            Gateway to<br />Asia Pacific
          </h2>
        </div>
        <div class="grid grid-cols-2 gap-6">
          <div class="border-l-2 border-[#e31937] pl-5">
            <div class="font-heading font-bold text-4xl text-white mb-1">2nd</div>
            <p class="font-body text-gray-400 text-sm leading-snug">Busiest Airport<br />in Canada</p>
          </div>
          <div class="border-l-2 border-[#e31937] pl-5">
            <div class="font-heading font-bold text-4xl text-white mb-1">Largest</div>
            <p class="font-body text-gray-400 text-sm leading-snug">Port<br />in Canada</p>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- ABOUT / MISSION SECTION -->
  <section class="bg-white py-24 reveal">
    <div class="max-w-7xl mx-auto px-6">
      <div class="grid grid-cols-1 lg:grid-cols-2 gap-16 items-start">

        <!-- Left: Origin story -->
        <div>
          <p class="font-heading font-bold text-sm tracking-widest uppercase text-[#e31937] mb-4">WHO WE ARE</p>
          <h2 class="font-heading font-bold uppercase text-5xl md:text-6xl text-[#0a0a0a] leading-tight mb-6">
            BUILT FROM<br />EXPERIENCE
          </h2>
          <p class="font-body text-gray-500 text-base leading-relaxed mb-4">
            Founded in 2015 by professionals with backgrounds in the financial industry, Synchron Logistics was built on a simple insight: the gap in international shipping was costing businesses time and money.
          </p>
          <p class="font-body text-gray-500 text-base leading-relaxed">
            Today, we're one of the leading companies in global logistics — covering international freight forwarding, inland distribution, and complete supply chain logistics support from our base in Kelowna, BC.
          </p>
        </div>

        <!-- Right: Mission callout -->
        <div class="flex flex-col gap-8 lg:pt-14">
          <div class="border-l-4 border-[#e31937] pl-6">
            <p class="font-heading font-bold text-2xl md:text-3xl text-[#0a0a0a] leading-snug">
              "Driven by purpose.<br />Fueled by opportunity."
            </p>
          </div>
          <p class="font-body text-gray-500 text-base leading-relaxed">
            Everything we do is focused on making our customers' business lives easier — helping them reduce logistics costs, shorten supply chain cycle times, and enable growth.
          </p>
          <a
            href="/about"
            class="read-more-link font-heading font-bold text-xs tracking-widest uppercase text-[#e31937] flex items-center gap-2 self-start"
          >
            OUR STORY
            <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7"/>
            </svg>
          </a>
        </div>

      </div>
    </div>
  </section>

  <!-- SERVICES SECTION -->
  <section class="bg-[#f5f5f5] py-24 reveal">
    <div class="max-w-7xl mx-auto px-6">
      <!-- Header -->
      <div class="text-center mb-16">
        <p class="font-heading font-bold text-sm tracking-widest uppercase text-[#e31937] mb-3">OUR SERVICES</p>
        <h2 class="font-heading font-bold uppercase text-5xl md:text-6xl text-[#0a0a0a]">END-TO-END SOLUTIONS</h2>
      </div>

      <!-- Cards -->
      <div class="grid grid-cols-1 md:grid-cols-3 gap-8">
        <!-- International Freight -->
        <div class="bg-white overflow-hidden service-card">
          <div class="relative service-img-wrap">
            <img
              src="https://images.unsplash.com/photo-1494412574643-ff11b0a5c1c3?w=800&q=80"
              alt="International freight — air and ocean"
              class="w-full h-56 object-cover"
              loading="lazy"
            />
            <div class="absolute bottom-0 right-0 w-12 h-12 bg-[#e31937] flex items-center justify-center" style="z-index:1;">
              <svg class="w-6 h-6 text-white" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M12 19l9 2-9-18-9 18 9-2zm0 0v-8"/>
              </svg>
            </div>
            <div class="service-overlay">
              <a href="/services" class="service-learn-more">LEARN MORE</a>
            </div>
          </div>
          <div class="p-6">
            <h3 class="font-heading font-bold text-xl uppercase text-[#0a0a0a] mb-3">International Freight</h3>
            <p class="font-body text-gray-500 text-sm leading-relaxed mb-5">IATA-accredited air freight and FMC-registered ocean freight. FCL, LCL, direct and deferred options — worldwide reach.</p>
            <a href="/services" class="read-more-link font-heading font-bold text-xs tracking-widest uppercase text-[#e31937] flex items-center gap-2">
              READ MORE
              <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7"/>
              </svg>
            </a>
          </div>
        </div>

        <!-- Domestic Transportation -->
        <div class="bg-white overflow-hidden service-card">
          <div class="relative service-img-wrap">
            <img
              src="https://images.unsplash.com/photo-1601584115197-04ecc0da31d7?w=800&q=80"
              alt="Road transportation and drayage"
              class="w-full h-56 object-cover"
              loading="lazy"
            />
            <div class="absolute bottom-0 right-0 w-12 h-12 bg-[#e31937] flex items-center justify-center" style="z-index:1;">
              <svg class="w-6 h-6 text-white" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M8.25 18.75a1.5 1.5 0 01-3 0m3 0a1.5 1.5 0 00-3 0m3 0h6m-9 0H3.375a1.125 1.125 0 01-1.125-1.125V14.25m17.25 4.5a1.5 1.5 0 01-3 0m3 0a1.5 1.5 0 00-3 0m3 0h1.125c.621 0 1.129-.504 1.09-1.124a17.902 17.902 0 00-3.213-9.193 2.056 2.056 0 00-1.58-.86H14.25M16.5 18.75h-2.25m0-11.177v-.958c0-.568-.422-1.048-.987-1.106a48.554 48.554 0 00-10.026 0 1.106 1.106 0 00-.987 1.106v7.635m12-6.677v6.677m0 4.5v-4.5m0 0h-12"/>
              </svg>
            </div>
            <div class="service-overlay">
              <a href="/services" class="service-learn-more">LEARN MORE</a>
            </div>
          </div>
          <div class="p-6">
            <h3 class="font-heading font-bold text-xl uppercase text-[#0a0a0a] mb-3">Domestic Transportation</h3>
            <p class="font-body text-gray-500 text-sm leading-relaxed mb-5">FTL and LTL coast to coast. Cross-border Canada/USA. Drayage within a 200-mile radius and port-to-rail container movement.</p>
            <a href="/services" class="read-more-link font-heading font-bold text-xs tracking-widest uppercase text-[#e31937] flex items-center gap-2">
              READ MORE
              <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7"/>
              </svg>
            </a>
          </div>
        </div>

        <!-- Warehousing & Distribution -->
        <div class="bg-white overflow-hidden service-card">
          <div class="relative service-img-wrap">
            <img
              src="https://images.unsplash.com/photo-1587293852726-70cdb56c2866?w=800&q=80"
              alt="Warehousing and distribution"
              class="w-full h-56 object-cover"
              loading="lazy"
            />
            <div class="absolute bottom-0 right-0 w-12 h-12 bg-[#e31937] flex items-center justify-center" style="z-index:1;">
              <svg class="w-6 h-6 text-white" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M21 7.5l-9-5.25L3 7.5m18 0l-9 5.25m9-5.25v9l-9 5.25M3 7.5l9 5.25M3 7.5v9l9 5.25m0-9v9"/>
              </svg>
            </div>
            <div class="service-overlay">
              <a href="/services" class="service-learn-more">LEARN MORE</a>
            </div>
          </div>
          <div class="p-6">
            <h3 class="font-heading font-bold text-xl uppercase text-[#0a0a0a] mb-3">Warehousing & Distribution</h3>
            <p class="font-body text-gray-500 text-sm leading-relaxed mb-5">Bonded and non-bonded facilities across Canada and the US. Trans-load, cross-docking, and e-commerce order fulfillment.</p>
            <a href="/services" class="read-more-link font-heading font-bold text-xs tracking-widest uppercase text-[#e31937] flex items-center gap-2">
              READ MORE
              <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7"/>
              </svg>
            </a>
          </div>
        </div>
      </div>

      <div class="text-center mt-12">
        <a href="/services" class="font-heading font-bold uppercase tracking-widest text-sm px-8 py-4 border-2 border-[#0a0a0a] text-[#0a0a0a] hover:bg-[#0a0a0a] hover:text-white transition-all duration-200">
          VIEW ALL SERVICES
        </a>
      </div>
    </div>
  </section>

  <!-- STATS / CREDIBILITY BAR -->
  <section class="bg-[#0a0a0a] py-20 reveal" id="stats-section">
    <div class="max-w-7xl mx-auto px-6">
      <div class="grid grid-cols-2 lg:grid-cols-4 gap-10">
        <div class="text-center">
          <div class="font-heading font-bold text-5xl md:text-6xl text-white mb-3">
            2015
          </div>
          <p class="font-body text-xs tracking-widest uppercase text-gray-500">YEAR FOUNDED</p>
        </div>
        <div class="text-center">
          <div class="font-heading font-bold text-5xl md:text-6xl text-white mb-3">
            <span data-counter data-target="1000">1,000</span><span class="text-[#e31937]">+</span>
          </div>
          <p class="font-body text-xs tracking-widest uppercase text-gray-500">PARTNER CARRIERS</p>
        </div>
        <div class="text-center">
          <div class="font-heading font-bold text-5xl md:text-6xl text-white mb-3">
            <span data-counter data-target="10">10</span>
          </div>
          <p class="font-body text-xs tracking-widest uppercase text-gray-500">INDUSTRIES SERVED</p>
        </div>
        <div class="text-center">
          <div class="font-heading font-bold text-5xl md:text-6xl text-white mb-3">
            24/7
          </div>
          <p class="font-body text-xs tracking-widest uppercase text-gray-500">365 SERVICE</p>
        </div>
      </div>
    </div>
  </section>

  <!-- CTA SECTION -->
  <section class="bg-[#e31937] py-24 reveal">
    <div class="max-w-7xl mx-auto px-6 text-center">
      <p class="font-heading font-bold text-sm tracking-widest uppercase text-white/60 mb-4">READY TO MOVE?</p>
      <h2 class="font-heading font-bold uppercase text-4xl md:text-5xl text-white mb-10">LET'S BUILD YOUR SOLUTION</h2>
      <a
        href="/contact"
        class="font-heading font-bold uppercase tracking-widest text-sm px-16 py-5 border-2 border-white text-white hover:bg-white hover:text-[#e31937] transition-all duration-200"
      >
        CONTACT US
      </a>
    </div>
  </section>

</Layout>

<style>
  /* =============================================
     HERO — PAGE LOAD STAGGER + FLOAT
  ============================================= */
  @media (prefers-reduced-motion: no-preference) {
    @keyframes fadeSlideUp {
      from { opacity: 0; transform: translateY(30px); }
      to   { opacity: 1; transform: translateY(0);    }
    }

    @keyframes float {
      0%, 100% { transform: translateY(0px);  }
      50%       { transform: translateY(-8px); }
    }

    .hero-eyebrow {
      animation: fadeSlideUp 0.7s ease-out 0.0s both;
    }
    .hero-line-1 {
      animation: fadeSlideUp 0.8s ease-out 0.15s both;
    }
    .hero-line-2 {
      animation: fadeSlideUp 0.8s ease-out 0.35s both;
    }
    .hero-subtext {
      animation: fadeSlideUp 0.7s ease-out 0.55s both;
    }
    .hero-buttons {
      animation: fadeSlideUp 0.7s ease-out 0.75s both;
    }
    .hero-float {
      animation: float 6s ease-in-out 1.5s infinite;
    }
  }

  /* =============================================
     SERVICES — IMAGE OVERLAY + CARD LIFT
  ============================================= */
  .service-card {
    transition: transform 0.3s ease, box-shadow 0.3s ease;
    cursor: pointer;
  }

  @media (prefers-reduced-motion: no-preference) {
    .service-card:hover {
      transform: translateY(-4px);
      box-shadow: 0 12px 40px rgba(0, 0, 0, 0.12);
    }
  }

  .service-img-wrap {
    position: relative;
    overflow: hidden;
  }

  @media (prefers-reduced-motion: no-preference) {
    .service-img-wrap img {
      transition: transform 0.4s ease;
    }
    .service-card:hover .service-img-wrap img {
      transform: scale(1.05);
    }
  }

  .service-overlay {
    position: absolute;
    inset: 0;
    background: rgba(0, 0, 0, 0.6);
    opacity: 0;
    transition: opacity 0.3s ease;
    display: flex;
    align-items: center;
    justify-content: center;
    z-index: 2;
  }
  .service-card:hover .service-overlay {
    opacity: 1;
  }

  .service-learn-more {
    color: white;
    border: 1px solid white;
    background: transparent;
    font-family: 'Barlow Condensed', sans-serif;
    font-weight: 700;
    font-size: 0.75rem;
    letter-spacing: 0.15em;
    text-transform: uppercase;
    padding: 0.75rem 1.75rem;
    text-decoration: none;
    cursor: pointer;
    opacity: 0;
    transform: translateY(10px);
    transition: opacity 0.3s ease, transform 0.3s ease;
  }
  @media (prefers-reduced-motion: no-preference) {
    .service-card:hover .service-learn-more {
      opacity: 1;
      transform: translateY(0);
    }
  }

  /* =============================================
     READ MORE — ARROW SHIFT
  ============================================= */
  @media (prefers-reduced-motion: no-preference) {
    .read-more-link svg {
      transition: transform 0.2s ease;
    }
    .read-more-link:hover svg {
      transform: translateX(4px);
    }
  }
</style>
