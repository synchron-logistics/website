---
import Layout from '../layouts/Layout.astro';
---

<Layout title="About Us — Synchron Logistics">
  <section class="bg-white py-32">
    <div class="max-w-7xl mx-auto px-6">
      <div class="grid grid-cols-1 lg:grid-cols-2 gap-16 items-center">
        <div>
          <p class="font-heading font-bold text-sm tracking-widest uppercase text-[#e31937] mb-4">ABOUT US</p>
          <h1 class="font-heading font-bold uppercase text-6xl md:text-7xl text-[#0a0a0a] leading-tight mb-6">
            YES IS OUR<br />STARTING LINE
          </h1>
          <p class="font-body text-gray-500 text-lg leading-relaxed mb-6">
            Since 2000, Synchron Logistics has been providing world-class logistics and supply chain solutions. We move your business forward with precision and reliability.
          </p>
          <p class="font-body text-gray-500 text-base leading-relaxed">
            We embrace a good challenge and take pride in our innovative approach. Every solution is custom-built for your unique need — because we know that no two supply chains are exactly alike.
          </p>
        </div>
        <div class="grid grid-cols-2 gap-6">
          {[
            { number: '25+', label: 'Years of Experience' },
            { number: '99%+', label: 'On-Time Delivery' },
            { number: '50K+', label: 'Truckloads / Month' },
            { number: '3.5M+', label: 'Sq Ft Warehouse' },
          ].map(stat => (
            <div class="bg-[#f5f5f5] p-8">
              <div class="font-heading font-bold text-4xl text-[#e31937] mb-2">{stat.number}</div>
              <p class="font-body text-sm text-gray-500 uppercase tracking-wide">{stat.label}</p>
            </div>
          ))}
        </div>
      </div>
    </div>
  </section>

  <section class="bg-[#0a0a0a] py-24">
    <div class="max-w-7xl mx-auto px-6">
      <div class="grid grid-cols-1 md:grid-cols-3 gap-10">
        {[
          { num: '01', title: 'Custom Solutions', body: 'We embrace a good challenge and take pride in our innovative approach. Every solution is custom-built for your unique need.' },
          { num: '02', title: 'Excellence in Execution', body: 'We deliver excellence in execution, technology, and capacity—driven by the best people in the industry.' },
          { num: '03', title: 'People Driven', body: 'Our people and culture drive our success. We take the time to build relationships with customers in ways that others don\'t.' },
        ].map(item => (
          <div>
            <div class="font-heading font-bold text-6xl text-gray-700 mb-4">{item.num}</div>
            <h3 class="font-heading font-bold text-2xl uppercase text-white mb-3">{item.title}</h3>
            <p class="font-body text-gray-400 text-sm leading-relaxed">{item.body}</p>
          </div>
        ))}
      </div>
    </div>
  </section>
</Layout>
