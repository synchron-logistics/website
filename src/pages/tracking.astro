---
import Layout from '../layouts/Layout.astro';
import { site } from '../../site.config.js';

// TODO: Replace with actual portal embed or login link once
// client confirms portal URL and Synch101 app status
---

<Layout title={`Track Shipment${site.seo.titleSuffix}`}>

  <!-- HERO -->
  <section class="bg-[#0a0a0a] py-32">
    <div class="max-w-7xl mx-auto px-6 text-center">
      <p class="font-heading font-bold text-sm tracking-widest uppercase text-[#e31937] mb-4">REAL-TIME TRACKING</p>
      <h1 class="font-heading font-bold uppercase text-6xl md:text-7xl text-white mb-6 leading-tight">
        REAL-TIME<br />SHIPMENT TRACKING
      </h1>
      <p class="font-body text-gray-400 text-lg max-w-xl mx-auto">
        Full visibility into your freight, wherever it is.
      </p>
    </div>
  </section>

  <!-- PORTAL INFO -->
  <section class="bg-white py-24">
    <div class="max-w-7xl mx-auto px-6">
      <div class="max-w-2xl mx-auto text-center">

        <!-- Portal icon -->
        <div class="w-16 h-16 bg-[#f5f5f5] flex items-center justify-center mx-auto mb-8">
          <svg class="w-8 h-8 text-[#e31937]" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M9 20l-5.447-2.724A1 1 0 013 16.382V5.618a1 1 0 011.447-.894L9 7m0 13l6-3m-6 3V7m6 10l4.553 2.276A1 1 0 0021 18.382V7.618a1 1 0 00-.553-.894L15 4m0 13V4m0 0L9 7"/>
          </svg>
        </div>

        <h2 class="font-heading font-bold uppercase text-4xl text-[#0a0a0a] mb-6">YOUR CUSTOMER PORTAL</h2>
        <p class="font-body text-gray-500 text-base leading-relaxed mb-4">
          Our customer portal gives you end-to-end visibility across all your shipments. Login credentials are provided when you become a Synchron client.
        </p>
        <p class="font-body text-gray-500 text-base leading-relaxed mb-10">
          Not a client yet? Contact our team to get started.
        </p>

        <a
          href="/contact"
          class="font-heading font-bold uppercase tracking-widest text-sm px-10 py-4 bg-[#e31937] text-white hover:bg-[#c41530] hover:scale-[1.02] transition-all duration-200 inline-block"
        >
          CONTACT US
        </a>
      </div>
    </div>
  </section>

  <!-- WHAT YOU GET -->
  <section class="bg-[#f5f5f5] py-20 reveal">
    <div class="max-w-7xl mx-auto px-6">
      <div class="text-center mb-12">
        <p class="font-heading font-bold text-sm tracking-widest uppercase text-[#e31937] mb-3">PORTAL FEATURES</p>
        <h2 class="font-heading font-bold uppercase text-4xl text-[#0a0a0a]">FULL SHIPMENT VISIBILITY</h2>
      </div>
      <div class="grid grid-cols-1 md:grid-cols-3 gap-6">
        {[
          {
            title: 'Live Status Updates',
            desc: 'Track your shipments in real time — from pickup through final delivery, across all modes.',
            icon: `<path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M13 10V3L4 14h7v7l9-11h-7z"/>`,
          },
          {
            title: 'Document Management',
            desc: 'Access bills of lading, customs documents, and delivery confirmations in one place.',
            icon: `<path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M9 12h6m-6 4h6m2 5H7a2 2 0 01-2-2V5a2 2 0 012-2h5.586a1 1 0 01.707.293l5.414 5.414a1 1 0 01.293.707V19a2 2 0 01-2 2z"/>`,
          },
          {
            title: 'Multi-Mode Coverage',
            desc: 'Air, ocean, road, and intermodal shipments — all visible in a single dashboard.',
            icon: `<path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M9 20l-5.447-2.724A1 1 0 013 16.382V5.618a1 1 0 011.447-.894L9 7m0 13l6-3m-6 3V7m6 10l4.553 2.276A1 1 0 0021 18.382V7.618a1 1 0 00-.553-.894L15 4m0 13V4m0 0L9 7"/>`,
          },
        ].map(feature => (
          <div class="bg-white p-8 border border-gray-100">
            <svg class="w-8 h-8 text-[#e31937] mb-4" fill="none" stroke="currentColor" viewBox="0 0 24 24" set:html={feature.icon} />
            <h3 class="font-heading font-bold text-xl uppercase text-[#0a0a0a] mb-3">{feature.title}</h3>
            <p class="font-body text-gray-500 text-sm leading-relaxed">{feature.desc}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

</Layout>
