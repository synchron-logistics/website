---
import Layout from '../layouts/Layout.astro';
---

<Layout title="Track Shipment — Synchron Logistics">
  <section class="bg-[#0a0a0a] py-32">
    <div class="max-w-7xl mx-auto px-6 text-center">
      <p class="font-heading font-bold text-sm tracking-widest uppercase text-[#e31937] mb-4">REAL-TIME TRACKING</p>
      <h1 class="font-heading font-bold uppercase text-6xl md:text-7xl text-white mb-6">TRACK YOUR SHIPMENT</h1>
      <p class="font-body text-gray-400 text-lg max-w-xl mx-auto mb-12">
        Enter your tracking number below to get real-time updates on your shipment status.
      </p>
      <div class="flex flex-col sm:flex-row gap-0 max-w-lg mx-auto">
        <input
          type="text"
          placeholder="Enter tracking number..."
          class="flex-1 px-6 py-4 font-body text-[#0a0a0a] bg-white focus:outline-none"
        />
        <button class="bg-[#e31937] text-white font-heading font-bold uppercase tracking-widest text-sm px-8 py-4 hover:bg-red-700 transition-colors">
          TRACK
        </button>
      </div>
    </div>
  </section>

  <section class="bg-[#f5f5f5] py-24">
    <div class="max-w-7xl mx-auto px-6 text-center">
      <h2 class="font-heading font-bold uppercase text-4xl text-[#0a0a0a] mb-4">24/7 DISPATCH + VISIBILITY</h2>
      <p class="font-body text-gray-500 text-lg max-w-2xl mx-auto">
        Our advanced tracking system provides real-time visibility into your shipments, giving you complete control and peace of mind throughout the entire journey.
      </p>
    </div>
  </section>
</Layout>
