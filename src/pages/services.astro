---

<Layout title={`Services${site.seo.titleSuffix}`}>

  <!-- PAGE HEADER -->
  <section class="bg-[#f5f5f5] py-32">
    <div class="max-w-7xl mx-auto px-6 text-center">
      <p class="font-heading font-bold text-sm tracking-widest uppercase text-[#e31937] mb-4">OUR SERVICES</p>
      <h1 class="font-heading font-bold uppercase text-6xl md:text-7xl text-[#0a0a0a] mb-6">COMPREHENSIVE SOLUTIONS</h1>
      <p class="font-body text-gray-500 text-lg max-w-2xl mx-auto">
        From domestic road transportation to international freight forwarding, warehousing, and supply chain consulting — we move your freight anywhere in the world.
      </p>
    </div>
  </section>

  <!-- ALTERNATING SPLIT SERVICE GROUPS -->
  {serviceGroups.map((group, i) => {
    const isEven = i % 2 === 1;
    const contentBg = isEven ? 'bg-[#f5f5f5]' : 'bg-white';
    return (
      <section class="border-b border-gray-200 reveal" id={`group-0${i + 1}`}>
        <div class="grid grid-cols-1 lg:grid-cols-2">

          <!-- Image pane -->
          <!-- On mobile: always renders first (top). On desktop: left for odd groups, right for even. -->
          <div
            class={`relative min-h-[300px] lg:min-h-0 bg-[#0a0a0a] overflow-hidden order-1 ${isEven ? 'lg:order-2' : ''}`}
          >
            <!-- Image file goes in /public/images/{group.image} -->
            <!-- Dark bg-[#0a0a0a] shows as placeholder until the file is present -->
            <img
              src={`/images/${group.image}`}
              alt={group.imageAlt}
              class="absolute inset-0 w-full h-full object-cover"
              loading="lazy"
            />
          </div>

          <!-- Content pane -->
          <div
            class={`${contentBg} order-2 ${isEven ? 'lg:order-1' : ''} px-10 py-14 md:px-14 lg:px-16 xl:px-20 flex flex-col justify-center`}
          >
            <span class="font-heading font-bold text-[7rem] leading-none text-gray-200 select-none -mb-4">
              {group.number}
            </span>
            <h2 class="font-heading font-bold text-2xl md:text-3xl uppercase text-[#0a0a0a] tracking-wider mb-8">
              {group.label}
            </h2>
            <ul class="divide-y divide-gray-200">
              {group.services.map(service => (
                <li class="py-5 first:pt-0 last:pb-0">
                  <h3 class="font-heading font-bold uppercase text-sm tracking-widest text-[#0a0a0a] mb-1">
                    {service.title}
                  </h3>
                  <p class="font-body text-gray-500 text-sm leading-relaxed">
                    {service.desc}
                  </p>
                </li>
              ))}
            </ul>
          </div>

        </div>
      </section>
    );
  })}

  <!-- INDUSTRIES WE SERVE -->
  <section class="bg-[#0a0a0a] py-24 reveal">
    <div class="max-w-7xl mx-auto px-6">
      <div class="text-center mb-16">
        <p class="font-heading font-bold text-sm tracking-widest uppercase text-[#e31937] mb-3">SECTORS</p>
        <h2 class="font-heading font-bold uppercase text-5xl md:text-6xl text-white">INDUSTRIES WE SERVE</h2>
      </div>
      <div class="grid grid-cols-2 md:grid-cols-3 lg:grid-cols-5 gap-4">
        {industries.map(industry => (
          <div class="industry-tile flex flex-col items-center gap-3 p-6 border border-gray-800 hover:border-[#e31937] transition-colors text-center">
            <svg
              class="w-8 h-8 text-gray-500 industry-icon"
              fill="none"
              stroke="currentColor"
              viewBox="0 0 24 24"
              set:html={industry.icon}
            />
            <p class="font-heading font-bold text-xs uppercase tracking-wide text-gray-400 industry-label leading-tight">
              {industry.label}
            </p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- CTA -->
  <section class="bg-[#e31937] py-20">
    <div class="max-w-7xl mx-auto px-6 flex flex-col md:flex-row items-center justify-between gap-8">
      <div>
        <h2 class="font-heading font-bold uppercase text-4xl md:text-5xl text-white leading-tight">READY TO SHIP?</h2>
        <p class="font-body text-white/80 text-base mt-2">Tell us what you need — we'll build the solution.</p>
      </div>
      <a
        href="/contact"
        class="font-heading font-bold uppercase tracking-widest text-sm px-10 py-4 border-2 border-white text-white hover:bg-white hover:text-[#e31937] transition-all duration-200 flex-shrink-0"
      >
        GET A QUOTE
      </a>
    </div>
  </section>

</Layout>

<style>
  @media (prefers-reduced-motion: no-preference) {
    .industry-icon,
    .industry-label {
      transition: color 0.2s ease;
    }
    .industry-tile:hover .industry-icon {
      color: #e31937;
    }
    .industry-tile:hover .industry-label {
      color: #ffffff;
    }
  }
</style>
