      {
        title: 'Road Transportation',
        desc: 'FTL, LTL, cross-border. Canada & USA coast to coast.',
      },
      {
        title: 'Drayage',
        desc: 'Short-haul within 200-mile radius. Port-to-rail container movement.',
      },
      {
        title: 'Cross-Border Services',
        desc: 'Bond-trucking, customs brokers, intermodal partners. FTL and LTL.',
      },
    ],
  },
  {
    number: '02',
    label: 'INTERNATIONAL FREIGHT',
    image: 'synchron-logistics-international-freight.jpg',
    imageAlt: 'Cargo aircraft on a runway',
    imageHint: 'cargo plane airport freight',
    services: [
      {
        title: 'Air Freight',
        desc: 'IATA-accredited. Express (1–2 days), standard (3–5 days), charter, AOG & NFO. Any size.',
      },
      {
        title: 'Ocean Freight',
        desc: 'FMC-registered NVOCC. FCL & LCL. Full documentation, drayage, and consolidation.',
      },
      {
        title: 'Cross-Border',
        desc: 'Canada, USA, Europe & Africa. FTL and LTL.',
      },
    ],
  },
  {
    number: '03',
    label: 'WAREHOUSING & DISTRIBUTION',
    image: 'synchron-logistics-warehouse-distribution.jpg',
    imageAlt: 'Warehouse interior with forklift',
    imageHint: 'warehouse forklift',
    services: [
      {
        title: 'Warehousing',
        desc: 'Bonded & non-bonded facilities across Canada & US.',
      },
      {
        title: 'Trans-Load & Cross-Docking',
        desc: 'Segregation and palletizing hub for your supply chain.',
      },
      {
        title: 'E-Commerce Fulfillment',
        desc: 'Inventory management and order fulfillment.',
      },
      {
        title: 'Intermodal',
        desc: 'Seamless movement across truck, rail, and cargo ship.',
      },
    ],
  },
  {
    number: '04',
    label: 'VALUE-ADDED SERVICES',
    image: 'synchron-logistics-value-added-services.jpg',
    imageAlt: 'Logistics team in a meeting',
    imageHint: 'business meeting logistics',
    services: [
      {
        title: 'Supply Chain Consulting',
        desc: 'Network design, cost analysis, process optimization, risk management.',
