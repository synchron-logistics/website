---
import Layout from '../layouts/Layout.astro';
import { site } from '../../site.config.js';

const { phone, phoneHref, email, address, emails } = site;
---

<Layout title={`Contact${site.seo.titleSuffix}`}>
  <section class="bg-[#f5f5f5] py-32">
    <div class="max-w-7xl mx-auto px-6">
      <div class="grid grid-cols-1 lg:grid-cols-2 gap-16">

        <!-- Left: Info -->
        <div>
          <p class="font-heading font-bold text-sm tracking-widest uppercase text-[#e31937] mb-4">GET IN TOUCH</p>
          <h1 class="font-heading font-bold uppercase text-6xl md:text-7xl text-[#0a0a0a] leading-tight mb-6">
            LET'S MOVE<br />FORWARD
          </h1>
          <p class="font-body text-gray-500 text-lg leading-relaxed mb-12">
            Ready to simplify your supply chain? Our team is available 24/7/365 to discuss your logistics needs and build a custom solution for your business.
          </p>
          <div class="flex flex-col gap-6">
            {address.street && (
              <div class="flex items-start gap-4">
                <div class="w-10 h-10 bg-[#e31937] flex items-center justify-center flex-shrink-0">
                  <svg class="w-5 h-5 text-white" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z"/>
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 11a3 3 0 11-6 0 3 3 0 016 0z"/>
                  </svg>
                </div>
                <div>
                  <p class="font-heading font-bold text-sm uppercase tracking-wider text-[#0a0a0a] mb-1">Address</p>
                  <p class="font-body text-gray-500 text-sm">{address.street}<br/>{address.city}, {address.province} {address.postal}</p>
                </div>
              </div>
            )}
            {!address.street && (
              <div class="flex items-start gap-4">
                <div class="w-10 h-10 bg-[#e31937] flex items-center justify-center flex-shrink-0">
                  <svg class="w-5 h-5 text-white" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z"/>
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 11a3 3 0 11-6 0 3 3 0 016 0z"/>
                  </svg>
                </div>
                <div>
                  <p class="font-heading font-bold text-sm uppercase tracking-wider text-[#0a0a0a] mb-1">Location</p>
                  <p class="font-body text-gray-500 text-sm">{address.city}, {address.province}, {address.country}</p>
                </div>
              </div>
            )}
            {phone && (
              <div class="flex items-center gap-4">
                <div class="w-10 h-10 bg-[#e31937] flex items-center justify-center flex-shrink-0">
                  <svg class="w-5 h-5 text-white" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 5a2 2 0 012-2h3.28a1 1 0 01.948.684l1.498 4.493a1 1 0 01-.502 1.21l-2.257 1.13a11.042 11.042 0 005.516 5.516l1.13-2.257a1 1 0 011.21-.502l4.493 1.498a1 1 0 01.684.949V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 6V5z"/>
                  </svg>
                </div>
                <div>
                  <p class="font-heading font-bold text-sm uppercase tracking-wider text-[#0a0a0a] mb-1">Phone</p>
                  <a href={phoneHref} class="font-body text-gray-500 text-sm hover:text-[#e31937] transition-colors">{phone}</a>
                </div>
              </div>
            )}
            <div class="flex items-center gap-4">
              <div class="w-10 h-10 bg-[#e31937] flex items-center justify-center flex-shrink-0">
                <svg class="w-5 h-5 text-white" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 8l7.89 5.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z"/>
                </svg>
              </div>
              <div>
                <p class="font-heading font-bold text-sm uppercase tracking-wider text-[#0a0a0a] mb-1">Email</p>
                <a href={`mailto:${email}`} class="font-body text-gray-500 text-sm hover:text-[#e31937] transition-colors">{email}</a>
              </div>
            </div>
          </div>
        </div>

        <!-- Right: Form -->
        <!--
          Email routing (handled by Resend API endpoint when built):
          - General Inquiry   → site.emails.general    (info@synchronlogistics.com)
          - Sales & Quotes    → site.emails.sales       (sales@synchronlogistics.com)
          - Carrier Inquiries → site.emails.accounting  (accounting@synchronlogistics.com)
          The selected inquiry type value is submitted with the form and read by the endpoint.
          Do not hardcode email strings here — always reference site.config.js.
        -->
        <div class="bg-white p-10">
          <h2 class="font-heading font-bold uppercase text-3xl text-[#0a0a0a] mb-8">GET A QUOTE</h2>
          <!-- TODO: Wire to Resend API endpoint at src/pages/api/contact.ts -->
          <form class="flex flex-col gap-5">
            <div>
              <label class="font-body text-xs uppercase tracking-widest text-gray-500 mb-2 block">Inquiry Type</label>
              <select
                name="inquiryType"
                data-email-general={emails.general}
                data-email-sales={emails.sales}
                data-email-accounting={emails.accounting}
                class="w-full border border-gray-200 px-4 py-3 font-body text-sm focus:outline-none focus:border-[#e31937] transition-colors bg-white text-gray-700"
              >
                <option value="general">General Inquiry</option>
                <option value="sales">Sales &amp; Quotes</option>
                <option value="carrier">Carrier Inquiries</option>
              </select>
            </div>
            <div class="grid grid-cols-1 sm:grid-cols-2 gap-5">
              <div>
                <label class="font-body text-xs uppercase tracking-widest text-gray-500 mb-2 block">First Name</label>
                <input type="text" name="firstName" class="w-full border border-gray-200 px-4 py-3 font-body text-sm focus:outline-none focus:border-[#e31937] transition-colors" placeholder="John" />
              </div>
              <div>
                <label class="font-body text-xs uppercase tracking-widest text-gray-500 mb-2 block">Last Name</label>
                <input type="text" name="lastName" class="w-full border border-gray-200 px-4 py-3 font-body text-sm focus:outline-none focus:border-[#e31937] transition-colors" placeholder="Smith" />
              </div>
            </div>
            <div>
              <label class="font-body text-xs uppercase tracking-widest text-gray-500 mb-2 block">Email</label>
              <input type="email" name="email" class="w-full border border-gray-200 px-4 py-3 font-body text-sm focus:outline-none focus:border-[#e31937] transition-colors" placeholder="john@company.com" />
            </div>
            <div>
              <label class="font-body text-xs uppercase tracking-widest text-gray-500 mb-2 block">Company</label>
              <input type="text" name="company" class="w-full border border-gray-200 px-4 py-3 font-body text-sm focus:outline-none focus:border-[#e31937] transition-colors" placeholder="Your Company" />
            </div>
            <div>
              <label class="font-body text-xs uppercase tracking-widest text-gray-500 mb-2 block">Service Needed</label>
              <select name="service" class="w-full border border-gray-200 px-4 py-3 font-body text-sm focus:outline-none focus:border-[#e31937] transition-colors bg-white text-gray-500">
                <option value="">Select a service</option>
                <option>Air Freight</option>
                <option>Ocean Freight</option>
                <option>Road Transportation</option>
                <option>Drayage</option>
                <option>Cross-Border</option>
                <option>Warehousing & Distribution</option>
                <option>E-Commerce Fulfillment</option>
                <option>Supply Chain Consulting</option>
                <option>Freight Brokerage</option>
                <option>Special / Project Cargo</option>
              </select>
            </div>
            <div>
              <label class="font-body text-xs uppercase tracking-widest text-gray-500 mb-2 block">Message</label>
              <textarea name="message" rows="4" class="w-full border border-gray-200 px-4 py-3 font-body text-sm focus:outline-none focus:border-[#e31937] transition-colors resize-none" placeholder="Tell us about your logistics needs..."></textarea>
            </div>
            <button type="submit" class="bg-[#e31937] text-white font-heading font-bold uppercase tracking-widest text-sm px-8 py-4 hover:bg-[#c41530] transition-colors self-start">
              SEND MESSAGE
            </button>
          </form>
        </div>

      </div>
    </div>
  </section>
</Layout>
