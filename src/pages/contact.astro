---
import Layout from '../layouts/Layout.astro';
---

<Layout title="Contact — Synchron Logistics">
  <section class="bg-[#f5f5f5] py-32">
    <div class="max-w-7xl mx-auto px-6">
      <div class="grid grid-cols-1 lg:grid-cols-2 gap-16">
        <!-- Left: Info -->
        <div>
          <p class="font-heading font-bold text-sm tracking-widest uppercase text-[#e31937] mb-4">GET IN TOUCH</p>
          <h1 class="font-heading font-bold uppercase text-6xl md:text-7xl text-[#0a0a0a] leading-tight mb-6">
            LET'S MOVE<br />FORWARD
          </h1>
          <p class="font-body text-gray-500 text-lg leading-relaxed mb-12">
            Ready to simplify your supply chain? Our team is available 24/7 to discuss your logistics needs and build a custom solution for your business.
          </p>
          <div class="flex flex-col gap-6">
            <div class="flex items-start gap-4">
              <div class="w-10 h-10 bg-[#e31937] flex items-center justify-center flex-shrink-0">
                <svg class="w-5 h-5 text-white" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z"/>
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 11a3 3 0 11-6 0 3 3 0 016 0z"/>
                </svg>
              </div>
              <div>
                <p class="font-heading font-bold text-sm uppercase tracking-wider text-[#0a0a0a] mb-1">Address</p>
                <p class="font-body text-gray-500 text-sm">123 Logistics Way, Suite 500<br/>New York, NY 10001</p>
              </div>
            </div>
            <div class="flex items-center gap-4">
              <div class="w-10 h-10 bg-[#e31937] flex items-center justify-center flex-shrink-0">
                <svg class="w-5 h-5 text-white" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 5a2 2 0 012-2h3.28a1 1 0 01.948.684l1.498 4.493a1 1 0 01-.502 1.21l-2.257 1.13a11.042 11.042 0 005.516 5.516l1.13-2.257a1 1 0 011.21-.502l4.493 1.498a1 1 0 01.684.949V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 6V5z"/>
                </svg>
              </div>
              <div>
                <p class="font-heading font-bold text-sm uppercase tracking-wider text-[#0a0a0a] mb-1">Phone</p>
                <a href="tel:+18005550123" class="font-body text-gray-500 text-sm hover:text-[#e31937] transition-colors">+1 (800) 555-0123</a>
              </div>
            </div>
            <div class="flex items-center gap-4">
              <div class="w-10 h-10 bg-[#e31937] flex items-center justify-center flex-shrink-0">
                <svg class="w-5 h-5 text-white" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 8l7.89 5.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z"/>
                </svg>
              </div>
              <div>
                <p class="font-heading font-bold text-sm uppercase tracking-wider text-[#0a0a0a] mb-1">Email</p>
                <a href="mailto:info@synchronlogistics.com" class="font-body text-gray-500 text-sm hover:text-[#e31937] transition-colors">info@synchronlogistics.com</a>
              </div>
            </div>
          </div>
        </div>

        <!-- Right: Form -->
        <div class="bg-white p-10">
          <h2 class="font-heading font-bold uppercase text-3xl text-[#0a0a0a] mb-8">GET A QUOTE</h2>
          <form class="flex flex-col gap-5">
            <div class="grid grid-cols-1 sm:grid-cols-2 gap-5">
              <div>
                <label class="font-body text-xs uppercase tracking-widest text-gray-500 mb-2 block">First Name</label>
                <input type="text" class="w-full border border-gray-200 px-4 py-3 font-body text-sm focus:outline-none focus:border-[#e31937] transition-colors" placeholder="John" />
              </div>
              <div>
                <label class="font-body text-xs uppercase tracking-widest text-gray-500 mb-2 block">Last Name</label>
                <input type="text" class="w-full border border-gray-200 px-4 py-3 font-body text-sm focus:outline-none focus:border-[#e31937] transition-colors" placeholder="Smith" />
              </div>
            </div>
            <div>
              <label class="font-body text-xs uppercase tracking-widest text-gray-500 mb-2 block">Email</label>
              <input type="email" class="w-full border border-gray-200 px-4 py-3 font-body text-sm focus:outline-none focus:border-[#e31937] transition-colors" placeholder="john@company.com" />
            </div>
            <div>
              <label class="font-body text-xs uppercase tracking-widest text-gray-500 mb-2 block">Company</label>
              <input type="text" class="w-full border border-gray-200 px-4 py-3 font-body text-sm focus:outline-none focus:border-[#e31937] transition-colors" placeholder="Your Company" />
            </div>
            <div>
              <label class="font-body text-xs uppercase tracking-widest text-gray-500 mb-2 block">Service Needed</label>
              <select class="w-full border border-gray-200 px-4 py-3 font-body text-sm focus:outline-none focus:border-[#e31937] transition-colors bg-white text-gray-500">
                <option value="">Select a service</option>
                <option>Drayage + Intermodal</option>
                <option>Truckload + Transport</option>
                <option>Distribution + Fulfillment</option>
                <option>Ocean Freight</option>
                <option>Air Freight</option>
                <option>Supply Chain Consulting</option>
              </select>
            </div>
            <div>
              <label class="font-body text-xs uppercase tracking-widest text-gray-500 mb-2 block">Message</label>
              <textarea rows="4" class="w-full border border-gray-200 px-4 py-3 font-body text-sm focus:outline-none focus:border-[#e31937] transition-colors resize-none" placeholder="Tell us about your logistics needs..."></textarea>
            </div>
            <button type="submit" class="bg-[#e31937] text-white font-heading font-bold uppercase tracking-widest text-sm px-8 py-4 hover:bg-red-700 transition-colors self-start">
              SEND MESSAGE
            </button>
          </form>
        </div>
      </div>
    </div>
  </section>
</Layout>
